# Copy to .env and edit. Everything has safe defaults for local dev.
LVA_SECRET_KEY=generate-a-long-random-string-here
LVA_DATABASE_URL=sqlite:///labvisionai.db
LVA_TESSERACT_CMD=            # e.g. C:\Program Files\Tesseract-OCR\tesseract.exe on Windows
LVA_OCR_LANG=eng
LVA_YOLO_CONF=0.35
LVA_MAX_UPLOAD_MB=25
